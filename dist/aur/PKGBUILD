pkgname=reverso-linux
pkgver=0.0.1
pkgrel=1
pkgdesc="A Linux desktop translator using the Reverso API"
arch=('x86_64')
url="https://github.com/YOUR_USERNAME/reverso-linux"
license=('MIT')
depends=('gtk3' 'libcurl' 'json-c')
makedepends=('make' 'pkg-config')
source=("$pkgname-v$pkgver.tar.gz::https://github.com/YOUR_USERNAME/reverso-linux/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/$pkgname-v$pkgver"
  make
}

package() {
  cd "$srcdir/$pkgname-v$pkgver"
  make DESTDIR="$pkgdir" PREFIX=/usr install
}
